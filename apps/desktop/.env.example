# AWS credentials for S3 upload
# Copy this file to .env and fill in your values (never commit .env)

AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# S3 bucket where DMGs are uploaded (same bucket serving openclaw-easy.com)
S3_BUCKET=openclaw-easy.com-website

# Optional: folder prefix inside the bucket (default: downloads)
# S3_PREFIX=downloads
